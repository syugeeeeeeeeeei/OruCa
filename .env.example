# OruCa / Lab-Core v3 向け基本設定

# MySQLのデータベース名です。
# 通常はデフォルトのままで問題ありません。
MYSQL_DATABASE=OruCa_DB

# MySQLのアプリ用ユーザー名です。
# 他システムと共存する場合は衝突しない名前に変更してください。
MYSQL_USER=OruCa_user

# MySQLのアプリ用ユーザーのパスワードです。
# 本番では必ず強いパスワードに変更してください。
MYSQL_PASSWORD=OruCa_user_pass

# MySQLのrootユーザーのパスワードです。
# 保守作業で使うため、本番では必ず変更してください。
MYSQL_ROOT_PASSWORD=root

# 管理者ログイン用の固定パスワードです（必須）。
# 管理画面に入る全ユーザーが共通で入力するパスワードになるため、
# 本番では推測されにくい値に設定してください。
ADMIN_FIXED_PASSWORD=fukaya_lab

# Slack BotトークンをDBへ保存するときの暗号化キーです。
# Slack連携を使う場合は、十分に長くランダムな文字列を設定してください。
# （例: パスワードマネージャーで生成した32文字以上）
SLACK_TOKEN_ENC_KEY=please-set-a-strong-secret

# デバッグ管理者ログインを有効にするかどうかです。
# true: DEBUG_ADMIN_USER / DEBUG_ADMIN_PASSWORD でログイン可能
# false: 無効（本番は必ず false）
DEBUG_ADMIN_ENABLED=false

# デバッグ管理者ログイン用のユーザー名です。
# DEBUG_ADMIN_ENABLED=true のときだけ使われます。
DEBUG_ADMIN_USER=test-user

# デバッグ管理者ログイン用のパスワードです。
# DEBUG_ADMIN_ENABLED=true のときだけ使われます。
DEBUG_ADMIN_PASSWORD=test-password

# 永続データ保存先（ホスト側ディレクトリ）です。
# Lab-Core 標準構成では ../../appdata/oruca のままで問題ありません。
APPDATA_ROOT=../../appdata/oruca

# APIコンテナ内のバックアップ保存先パスです。
# 通常は /backups のままにしてください（composeで永続ボリュームに接続済み）。
BACKUP_DIR=/backups
